<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title or "LA SUERTE TE ESTÁ ESPERANDO" }}</title>
 <style>
  body {
    font-family: 'Segoe UI', Arial, sans-serif;
    margin: 0;
    padding: 0;
    line-height: 1.6;
    color: #333;
    background-color: #f9f9f9;
  }
  header {
    background: linear-gradient(to right, #d32f2f, #b71c1c);
    color: white;
    text-align: center;
    padding: 3rem 1rem;
  }
  header h1 {
    margin: 0;
    font-size: 3rem;
  }
  .container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }
  .info {
    background: white;
    padding: 2rem;
    border-radius: 10px;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    margin-bottom: 2rem;
  }
  .whatsapp-btn {
    display: inline-block;
    background: #25D366;
    color: white;
    padding: 1rem 2rem;
    border-radius: 50px;
    text-decoration: none;
    font-weight: bold;
    margin-top: 1rem;
  }
  .whatsapp-btn:hover {
    background: #128C7E;
  }
  h2 {
    color: #d32f2f;
    border-bottom: 2px solid #d32f2f;
    padding-bottom: 0.5rem;
  }
  ul {
    list-style: none;
    padding-left: 0;
  }
  ul li {
    margin: 0.8rem 0;
    font-size: 1.1rem;
  }
  ul li:before {
    content: "★ ";
    color: #d32f2f;
  }
</style>
</head>
<body>
{% include "nav.njk" %}
  {{ content | safe }}
<a href="https://wa.me/51992999864?text=¡Hola!%20Quiero%20información%20sobre%20sorteos%20o%20eventos" 
   class="whatsapp-float" target="_blank">
  <img src="https://upload.wikimedia.org/wikipedia/commons/6/6b/WhatsApp.svg" alt="WhatsApp" width="60">
</a>

<style>
  .whatsapp-float {
    position: fixed;
    width: 60px;
    height: 60px;
    bottom: 40px;
    right: 40px;
    background-color: #25d366;
    color: #fff;
    border-radius: 50px;
    text-align: center;
    font-size: 30px;
    box-shadow: 2px 2px 10px #999;
    z-index: 1000;
    transition: all 0.3s;
  }
  .whatsapp-float:hover {
    background-color: #128c7e;
    transform: scale(1.1);
  }
</style>
</body>
</html>